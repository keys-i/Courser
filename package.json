{
  "name": "courser-csse6400",
  "private": true,
  "version": "1.0.0",
  "description": "Courser - CSSE6400",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=high",
