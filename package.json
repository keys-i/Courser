{
  "name": "courser-csse6400",
  "private": true,
  "version": "1.0.0",
  "description": "Courser - CSSE6400",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=high",
    "security:smoke": "node scripts/security-smoke.mjs",
    "ci": "npm run typecheck && npm run test:run && npm run security:smoke && npm run build"
  },
  "dependencies": {
    "katex": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
